      "parameters": {
        "jsCode": "const booking = $input.first().json;\nconst request = $('Find Available Slot').first().json;\n\nconst meetingLink = booking.hangoutLink\n  || booking.conferenceData?.entryPoints?.find(e => e.entryPointType === 'video')?.uri\n  || '';\n\nreturn [{\n  json: {\n    ...request,\n    eventId: booking.id,\n    eventLink: booking.htmlLink,\n    meetingLink\n  }\n}];"
