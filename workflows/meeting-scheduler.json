    {
      "parameters": {
        "content": "## 2. Availability Check\nQuery Google Calendar free/busy across a search window, then walk working hours (Mon–Fri, 9am–5pm) to find the first slot that fits the requested duration — plus a few alternatives in case nothing's free.",
        "height": 340,
        "width": 560,
        "color": 6
      },
      "id": "b6ce345a-2e84-44c1-a303-2c840c0c50e3",
      "name": "Availability Check",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        -2256,
        592
      ]
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst tz = item.timezone || 'UTC';\n\nlet requestedStart = DateTime.fromFormat(`${item.requestedDate} ${item.requestedTime}`, 'yyyy-MM-dd HH:mm', { zone: tz });\nif (!requestedStart.isValid) {\n  requestedStart = DateTime.now().setZone(tz).plus({ hours: 2 }).set({ minute: 0, second: 0, millisecond: 0 });\n}\n\nconst now = DateTime.now().setZone(tz);\nconst windowStart = (requestedStart < now ? now : requestedStart).toISO();\nconst windowEnd = requestedStart.plus({ days: 14 }).toISO();\n\nreturn [{\n  json: {\n    ...item,\n    requestedStart: requestedStart.toISO(),\n    windowStart,\n    windowEnd\n  }\n}];"
      },
      "id": "06f29ff7-671e-4f37-894e-f98c6b0fd29b",
      "name": "Compute Search Window",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -2256,
        960
      ]
    },
    {
      "parameters": {
        "resource": "calendar",
        "calendar": {
          "__rl": true,
          "value": "primary",
          "mode": "list"
        },
        "timeMin": "={{ $json }}",
        "timeMax": "={{ $json.windowEnd }}",
        "options": {}
      },
      "id": "3e7fa8ab-494c-43bc-a22d-2eb88d151a7d",
      "name": "Get Busy Times",
      "type": "n8n-nodes-base.googleCalendar",
      "typeVersion": 1.3,
      "position": [
        -2032,
        960
      ],
      "credentials": {
        "googleCalendarOAuth2Api": {
          "id": "kZl5TKBGDvPThOw0",
          "name": "Google Calendar account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const request = $('Compute Search Window').first().json;\n\n// \"Get Busy Times\" can shape its output a couple of different ways depending\n// on node version/options - normalize them all into a flat {start, end} list.\nconst busyPeriods = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  if (j.start && j.end) {\n    busyPeriods.push({ start: j.start, end: j.end });\n  } else if (Array.isArray(j.busy)) {\n    for (const b of j.busy) busyPeriods.push({ start: b.start, end: b.end });\n  } else if (j.calendars) {\n    for (const cal of Object.values(j.calendars)) {\n      for (const b of (cal.busy || [])) busyPeriods.push({ start: b.start, end: b.end });\n    }\n  }\n}\n\nconst tz = request.timezone || 'UTC';\nconst durationMinutes = Number(request.duration) || 30;\nconst WORK_START_HOUR = 9;\nconst WORK_END_HOUR = 17;\nconst MAX_ALTERNATIVES = 3;\n\nconst overlaps = (aStart, aEnd, bStart, bEnd) => aStart < bEnd && bStart < aEnd;\n\nlet cursor = DateTime.fromISO(request.requestedStart, { zone: tz });\nif (!cursor.isValid) cursor = DateTime.now().setZone(tz);\n\nconst searchLimit = cursor.plus({ days: 14 });\nlet found = null;\nconst alternatives = [];\n\nwhile (cursor < searchLimit) {\n  if (cursor.weekday <= 5) {\n    const dayStart = cursor.set({ hour: WORK_START_HOUR, minute: 0, second: 0, millisecond: 0 });\n    const dayEnd = cursor.set({ hour: WORK_END_HOUR, minute: 0, second: 0, millisecond: 0 });\n    let slotStart = cursor > dayStart ? cursor : dayStart;\n\n    while (slotStart.plus({ minutes: durationMinutes }) <= dayEnd) {\n      const slotEnd = slotStart.plus({ minutes: durationMinutes });\n      const busy = busyPeriods.some(b => overlaps(\n        slotStart.toMillis(), slotEnd.toMillis(),\n        DateTime.fromISO(b.start).toMillis(), DateTime.fromISO(b.end).toMillis()\n      ));\n\n      if (!busy) {\n        if (!found) {\n          found = { start: slotStart.toISO(), end: slotEnd.toISO() };\n        } else if (alternatives.length < MAX_ALTERNATIVES) {\n          alternatives.push({ start: slotStart.toISO(), end: slotEnd.toISO() });\n        }\n      }\n\n      if (found && alternatives.length >= MAX_ALTERNATIVES) break;\n      slotStart = slotStart.plus({ minutes: 15 });\n    }\n  }\n\n  if (found && alternatives.length >= MAX_ALTERNATIVES) break;\n  cursor = cursor.plus({ days: 1 }).set({ hour: 0, minute: 0, second: 0, millisecond: 0 });\n}\n\nreturn [{\n  json: {\n    ...request,\n    slotFound: !!found,\n    slotStart: found ? found.start : null,\n    slotEnd: found ? found.end : null,\n    alternativeSlots: alternatives\n  }\n}];"
      },
      "id": "1b898b33-028c-447a-9bcc-e922299fc36d",
      "name": "Find Available Slot",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1808,
        960
      ]
    },
